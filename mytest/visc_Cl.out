------------------------------------
Reading input data for simulation 1.
------------------------------------

	DATABASE ../database/phreeqc.dat
	PRINT
	 echo_input false
	SOLUTION
	INCREMENTAL_REACTIONS true
	REACTION 1
	NaCl 1
	1e-3 10*0.01 9*0.1 9*0.6
	USER_GRAPH 1
	-connect_simulations false
	-plot_tsv_file vNaCl_25.dat
	-axis_titles "salt concentration / (mol/kgw)" "viscosity / (mPa s)"
	10 graph_x tot("Cl") 
	20 graph_y viscos
	END
