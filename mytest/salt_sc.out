	DATABASE ../database/phreeqc.dat
	PRINT
	 echo_input false
	SOLUTION_SPREAD
	 temp 20
	 units mol/L
	number	K	Cl	pH	density #     HB_SC
	1 	0.067	0.067	7 charge	1.0014 #     8200
	2 	0.134	0.134	7 charge	1.0045 #     15700
	3 	0.202	0.202	7 charge	1.0077 #     22700
	4 	0.270	0.270	7 charge	1.0109 #     29500
	5 	0.340	0.340	7 charge	1.0142 #     36500
	6 	0.409	0.409	7 charge	1.0173 #     43600
	7 	0.478	0.478	7 charge	1.0205 #     50600
	8 	0.549	0.549	7 charge	1.0238 #     57600
	9 	0.690	0.690	7 charge	1.0302 #     71900
	10	0.834	0.834	7 charge	1.0368 #     86200
	11	0.979	0.979	7 charge	1.0434 #     100000
	12	1.052	1.052	7 charge	1.0467 #     108000
	USER_GRAPH 
	  -headings KCl
	  -axis_titles "Handbook of Chemistry and Physics: SC / (mmho/cm)" "PHREEQC"
	  -axis_scale x_axis 0 120
	  -axis_scale y_axis 0 120
	  -initial_solutions true
	  10 DATA 8200, 15700, 22700, 29500, 36500, 43600, 50600, 57600, 71900, 86200, 100000, 108000
	  20 dim HB(12)
	  30 for i = 1 to cell_no 
	  40   READ HB(i)
	  50 next i
	  60 plot_xy HB(cell_no) / 1e3, SC / 1e3, line_width = 0
	END
